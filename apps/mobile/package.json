{
  "name": "@transit-hide-and-seek/mobile",
  "private": true,
  "version": "0.1.0",
  "main": "expo-router/entry",
  "type": "module",
  "description": "Expo mobile app shell for the transit hide-and-seek platform.",
  "scripts": {
    "start": "expo start --clear",
    "android": "expo start --clear --android",
    "ios": "expo start --clear --ios",
    "web": "expo start --clear --web",
    "typecheck": "tsc --noEmit -p tsconfig.json",
    "test:smoke": "node --experimental-strip-types --test tests/*.test.ts"
  },
  "dependencies": {
    "@expo/metro-runtime": "~55.0.6",
    "expo": "~55.0.6",
    "expo-constants": "~55.0.7",
    "expo-linking": "~55.0.7",
    "expo-location": "~55.1.2",
    "expo-router": "~55.0.5",
    "expo-status-bar": "~55.0.4",
    "react": "19.2.0",
    "react-dom": "19.2.0",
    "react-native": "0.83.2",
    "react-native-gesture-handler": "~2.30.0",
    "react-native-get-random-values": "^1.11.0",
    "react-native-safe-area-context": "~5.6.2",
    "react-native-screens": "~4.23.0",
    "react-native-svg": "15.15.3",
    "react-native-web": "~0.21.2"
  },
  "devDependencies": {
    "@types/react": "~19.2.2",
    "babel-preset-expo": "~55.0.4",
    "typescript": "~5.9.2"
  }
}
