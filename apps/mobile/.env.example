EXPO_PUBLIC_DEFAULT_RUNTIME_MODE=in_memory
EXPO_PUBLIC_ENABLE_IN_MEMORY_MODE=true
EXPO_PUBLIC_ENABLE_ONLINE_MODE=true
EXPO_PUBLIC_ENABLE_NEARBY_MODE=true
EXPO_PUBLIC_ENABLE_SINGLE_DEVICE_MODE=true
EXPO_PUBLIC_ENABLE_DEVELOPER_TOOLS=true
EXPO_PUBLIC_DEFAULT_MATCH_PREFIX=match
EXPO_PUBLIC_NEARBY_JOIN_TTL_SECONDS=600
